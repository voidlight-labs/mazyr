# .env.example for Mazyr

# LLM Configuration
MAZYR_API_KEY=your_kimi_api_key_here
MAZYR_BASE_URL=https://api.moonshot.cn/v1
MAZYR_MODEL=kimi-k2-6

# Local LLM
MAZYR_LOCAL_MODEL_PATH=/path/to/your/model.gguf

# Inference Preference: local, cloud, hybrid
MAZYR_INFERENCE_PREFERENCE=hybrid

# Memory
MAZYR_QDRANT_HOST=localhost
MAZYR_QDRANT_PORT=6333
MAZYR_SQLITE_PATH=./memory/mazyr.db

# Messenger
MAZYR_TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# GitHub Sync
MAZYR_GITHUB_TOKEN=your_github_token
MAZYR_GITHUB_REPO=yourusername/mazyr-memory

# Relay
MAZYR_RELAY_ENDPOINT=wss://relay.yourdomain.com
MAZYR_INSTANCE_ID=aria-001
